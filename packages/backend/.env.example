PORT=4000
NODE_ENV=development

DATABASE_URL=postgres://postgres:postgres@localhost:5432/trelloclone

# REQUIRED (no default): min 32 chars each. Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_ISS=trelloclone
JWT_AUD=trelloclone-web
REFRESH_TTL_MS=604800000

# Set false only for local HTTP dev; true in any deployed env.
COOKIE_SECURE=true
CORS_ORIGIN=http://localhost:5173

BCRYPT_COST=12

MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@trelloclone.dev
